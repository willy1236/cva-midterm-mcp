# OpenAI-compatible API settings
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# MCP server settings
# If AUTO_START_LOCAL_MCP=1, the client will start the local MCP server from main.py automatically.
AUTO_START_LOCAL_MCP=1
MCP_SERVER_URL=http://127.0.0.1:8001/mcp
MCP_HOST=127.0.0.1
MCP_PORT=8001
MCP_PATH=/mcp

# Host server settings
HOST_SERVER_BIND=127.0.0.1
HOST_SERVER_PORT=8010
HOST_SERVER_URL=http://127.0.0.1:8010
HOST_SESSION_FILE=host_sessions.json
GOVERNANCE_AUDIT_FILE=logs/governance_audit.jsonl

# CLI settings
HOST_CHAT_TIMEOUT=300
